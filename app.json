{
  "expo": {
    "name": "Briland",
    "slug": "briland-native-premium",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.briland.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "A Briland usa suas fotos somente quando você escolhe uma imagem para enviar ao catálogo.",
        "NSCameraUsageDescription": "A Briland usa a câmera somente quando você decide fotografar uma imagem para o catálogo.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "package": "com.briland.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#021126"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/icon-192.png",
      "backgroundColor": "#021126"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/briland-logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#021126"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "A Briland usa suas fotos somente quando você escolhe uma imagem para enviar ao catálogo.",
          "cameraPermission": "A Briland usa a câmera somente quando você decide fotografar uma imagem para o catálogo.",
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ceca3f97-fde1-4ffe-871b-11e12f41d2d6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ceca3f97-fde1-4ffe-871b-11e12f41d2d6"
    }
  }
}
