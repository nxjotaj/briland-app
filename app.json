{
  "expo": {
    "name": "Briland",
    "slug": "briland-native-premium",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/briland-logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.briland.app"
    },
    "android": {
      "package": "com.briland.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/briland-logo.png",
        "backgroundColor": "#021126"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/briland-logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#021126"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ceca3f97-fde1-4ffe-871b-11e12f41d2d6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ceca3f97-fde1-4ffe-871b-11e12f41d2d6"
    }
  }
}
